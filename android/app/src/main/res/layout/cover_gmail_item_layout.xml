<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gmail_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:background="@drawable/widget_list_item_ripple">

    <!-- 삭제 버튼 숨김 (gmail.readonly: 쓰기 불가) -->
    <TextView
        android:id="@+id/gmail_item_delete"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- 텍스트 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <!-- 첫 번째 줄: 보낸 사람 + 시간 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/gmail_item_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textSize="14sp"
                android:textColor="#7070A0" />

            <TextView
                android:id="@+id/gmail_item_sender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/gmail_item_time"
                android:layout_centerVertical="true"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingEnd="4dp" />

        </RelativeLayout>

        <!-- 두 번째 줄: 이메일 제목 -->
        <TextView
            android:id="@+id/gmail_item_subject"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="#B0B0C0"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="4dp" />

    </LinearLayout>

</RelativeLayout>
