<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E1E2E"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="위젯 화면 설정"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/configure_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#8888AA"
        android:textSize="13sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_cover"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="커버화면 위젯"
        android:textSize="15sp"
        android:backgroundTint="#3A3A5A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_home"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="홈화면 위젯"
        android:textSize="15sp"
        android:backgroundTint="#3A3A5A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_auto"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="자동 감지 (기본값)"
        android:textSize="15sp"
        android:backgroundTint="#2A2A3A"
        android:textColor="#8888AA"/>

</LinearLayout>
