<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="위젯 화면 설정"
        android:textColor="#FFFFFF"
        android:textSize="19sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/configure_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#9090A8"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_cover"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="커버화면 위젯으로 설정"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_dialog_default"
        android:backgroundTint="@null"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_home"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="홈화면 위젯으로 설정"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_dialog_default"
        android:backgroundTint="@null"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_auto"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="화면 자동 감지 (권장)"
        android:textSize="14sp"
        android:textColor="#A0A0B0"
        android:background="@drawable/btn_dialog_default"
        android:backgroundTint="@null"/>

</LinearLayout>
